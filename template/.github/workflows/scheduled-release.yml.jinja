name: Scheduled Release

on:
  schedule:
    - cron: "0 9 1 * *"
  workflow_dispatch:

permissions: {}

concurrency:
  group: {{ '${{ github.workflow }}' }}
  cancel-in-progress: false

jobs:
  bump:
    name: Bump version from conventional commits
    runs-on: ubuntu-latest
    timeout-minutes: 10
    permissions:
      id-token: write
    steps:
{% if harden_runner %}
      - name: Harden Runner
        uses: step-security/harden-runner@f808768d1510423e83855289c910610ca9b43176 # v2.17.0
        with:
          egress-policy: audit
          disable-telemetry: "true"
          disable-sudo-and-containers: "true"
{% endif %}
      - name: Obtain token
        id: octo-sts
        uses: octo-sts/action@f603d3be9d8dd9871a265776e625a27b00effe05 # v1.1.1
        with:
          scope: {{ github_owner }}/{{ project_name }}
          identity: scheduled-release
      - name: Checkout
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
        with:
          fetch-depth: 0
          filter: "blob:none"
          persist-credentials: false
      - name: Configure git remote
        env:
          GH_TOKEN: {{ '${{ steps.octo-sts.outputs.token }}' }}
        run: |
          git remote set-url origin "https://x-access-token:${GH_TOKEN}@github.com/{{ github_owner }}/{{ project_name }}.git"
      - name: Install mise and tools
        uses: jdx/mise-action@1648a7812b9aeae629881980618f079932869151 # v4.0.1
        with:
          experimental: true
        env:
          GITHUB_TOKEN: {{ '${{ steps.octo-sts.outputs.token }}' }}
      - name: Run bump
        run: cog bump --auto
        env:
          GITHUB_TOKEN: {{ '${{ steps.octo-sts.outputs.token }}' }}
