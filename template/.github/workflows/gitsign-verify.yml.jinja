name: Verify Commit Signatures

on:
  pull_request:
    types: [opened, synchronize, reopened]
    branches: [main]

permissions: {}

concurrency:
  group: {{ '${{ github.workflow }}-${{ github.ref }}' }}
  cancel-in-progress: true

jobs:
  verify:
    name: Verify Sigstore commit signatures
    if: {{ "${{ !startsWith(github.head_ref, 'renovate/') }}" }}
    runs-on: ubuntu-latest
    timeout-minutes: 10
    permissions:
      contents: read
    steps:
{% if harden_runner %}
      - name: Harden Runner
        uses: step-security/harden-runner@f808768d1510423e83855289c910610ca9b43176 # v2.17.0
        with:
          egress-policy: audit
          disable-telemetry: "true"
          disable-sudo-and-containers: "true"
{% endif %}
      - name: Checkout PR head
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
        with:
          fetch-depth: 0
          persist-credentials: false
      - name: Install gitsign
        uses: chainguard-dev/actions/setup-gitsign@5a9aa9e1e5d2b6cf78b38b68e7db7c3df9e1c2db # main
      - name: Verify every commit in PR
        env:
          BASE: {{ '${{ github.event.pull_request.base.sha }}' }}
          HEAD: {{ '${{ github.event.pull_request.head.sha }}' }}
        run: |
          set -euo pipefail
          for sha in $(git rev-list "$BASE..$HEAD"); do
            echo "Verifying $sha"
            gitsign verify "$sha" \
              --certificate-identity-regexp="^.*@{{ identity_domain | replace('.', '\\.') }}$" \
              --certificate-oidc-issuer="https://github.com/login/oauth"
          done
