[settings]
experimental = true
env_cache = true
env_cache_ttl = "9h"
install_before = "7d"
pin = true
lockfile = true
locked = false
prefer_offline = true
disable_default_registry = true
disable_backends = ["asdf", "vfox", "ubi"]

[tools]
"github:mongodb/kingfisher" = "1.98.0"
cocogitto = "6.5.0"
pinact = "3.9.2"
prek = "0.3.9"
syft = "1.42.4"
{% if has_go %}
go = "1.26.2"
golangci-lint = "2.11.4"
{% endif %}
{% if has_dotnet %}
dotnet = "10.0.203"
{% endif %}
{% if has_dart %}
dart = "3.12.1"
{% endif %}

[tasks."secret:scan"]
run = "kingfisher scan . --no-validate --redact --format json --output kingfisher-results.json"
description = "Scan codebase for secrets with Kingfisher"
alias = "ss"

[tasks."secret:validate"]
run = "kingfisher scan . --redact --validation-rps 2"
description = "Validate (and revoke) live secrets found by Kingfisher"
alias = "sv"

[tasks.bump]
run = "cog bump --auto"
description = "Calculate next version from conventional commits and tag"

[tasks."release:sbom"]
run = "syft scan dir:. -o cyclonedx-json=out/sbom/{{ project_name }}.cdx.json"
description = "Generate CycloneDX SBOM for the workspace"
alias = "rsbom"
sources = [
{% if has_go %}
    "go.mod",
    "go.sum",
{% endif %}
{% if has_dotnet %}
    "**/*.csproj",
    "**/packages.lock.json",
    "Directory.Packages.props",
{% endif %}
{% if has_dart %}
    "pubspec.yaml",
    "pubspec.lock",
{% endif %}
]
outputs = ["out/sbom/**/*"]

[tasks.lint]
description = "Run all linting"
depends = ["lint:*"]
{% if has_go %}

[tasks.build]
run = "go build ./..."
description = "Build all Go packages"
alias = "b"

[tasks.test]
run = "go test ./..."
description = "Run all Go tests"
alias = "t"

[tasks."lint:go"]
run = "golangci-lint run ./... --fix"
description = "Lint Go code with autofix"
sources = ["**/*.go"]
{% endif %}
{% if has_dotnet %}

[tasks.build]
run = "dotnet build {{ project_name_pascal }}.slnx"
description = "Build the .NET solution"
alias = "b"
sources = [
    "src/**/*.cs",
    "src/**/*.csproj",
    "{{ project_name_pascal }}.slnx",
    "Directory.Build.props",
    "Directory.Build.targets",
    "Directory.Packages.props",
    "global.json",
]
outputs = ["src/**/bin/**/*", "src/**/obj/**/*"]

[tasks.test]
run = "dotnet test {{ project_name_pascal }}.slnx"
description = "Run .NET tests"
alias = "t"
sources = [
    "src/**/*.cs",
    "tests/**/*.cs",
    "test/**/*.cs",
    "src/**/*.csproj",
    "tests/**/*.csproj",
    "test/**/*.csproj",
    "{{ project_name_pascal }}.slnx",
    "Directory.Build.props",
    "Directory.Build.targets",
    "Directory.Packages.props",
]
outputs = ["tests/**/TestResults/**/*", "test/**/TestResults/**/*"]

[tasks.restore]
run = "dotnet restore {{ project_name_pascal }}.slnx"
description = "Restore NuGet packages"
alias = "r"
sources = [
    "src/**/*.csproj",
    "src/**/packages.lock.json",
    "{{ project_name_pascal }}.slnx",
    "Directory.Packages.props",
    "global.json",
    "nuget.config",
]
outputs = ["src/**/obj/project.assets.json"]

[tasks.format]
run = "dotnet format {{ project_name_pascal }}.slnx"
description = "Format code via .editorconfig rules"
alias = "fmt"

[tasks."format:check"]
run = "dotnet format {{ project_name_pascal }}.slnx --verify-no-changes"
description = "Verify formatting without changes"
alias = "fmtc"

[tasks.pack]
run = "dotnet pack {{ project_name_pascal }}.slnx --configuration Release --output out/packages"
description = "Build NuGet packages into out/packages"
sources = [
    "src/**/*.cs",
    "src/**/*.csproj",
    "src/**/PACKAGE.md",
    "{{ project_name_pascal }}.slnx",
    "Directory.Build.props",
    "Directory.Build.targets",
    "Directory.Packages.props",
]
outputs = ["out/packages/**/*"]
{% endif %}
{% if has_dart %}

[tasks.get]
run = "dart pub get"
description = "Resolve Dart dependencies into pubspec.lock"
alias = "g"
sources = ["pubspec.yaml"]
outputs = ["pubspec.lock"]

[tasks.test]
run = "dart test"
description = "Run Dart tests"
alias = "t"
sources = ["**/*.dart", "pubspec.yaml", "dart_test.yaml"]
outputs = ["coverage/**/*"]

[tasks.analyze]
run = "dart analyze"
description = "Run the Dart static analyzer"
alias = "a"
sources = ["**/*.dart", "analysis_options.yaml"]

[tasks.format]
run = "dart format ."
description = "Format Dart code in place"
alias = "fmt"

[tasks."format:check"]
run = "dart format --output=none --set-exit-if-changed ."
description = "Verify Dart formatting without changes"
alias = "fmtc"

[tasks."lint:dart"]
run = "dart analyze --fatal-infos --fatal-warnings"
description = "Treat analyzer infos and warnings as failures"
sources = ["**/*.dart", "analysis_options.yaml"]

[tasks.publish-dry]
run = "dart pub publish --dry-run"
description = "Verify publishability without uploading"
{% endif %}
