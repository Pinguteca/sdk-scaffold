[settings]
experimental = true
env_cache = true
env_cache_ttl = "9h"
install_before = "7d"
pin = true
lockfile = true
locked = false
prefer_offline = true
disable_default_registry = true
disable_backends = ["asdf", "vfox", "ubi"]

[tools]
"aqua:slsa-verifier" = "2.7.1"
{% if has_dotnet %}

[env]
# Nuget.org username of the individual account that created the trusted-
# publishing policy. NOT the package owner (the user or org that the
# package belongs to). NuGet's token-exchange endpoint requires the
# creators name even when the package itself is owned by an
# organization. Consumed by NuGet/login@v1 via the `user` input in
# release-dotnet.yml. Gitted (public) rather than a GitHub repo
# variable; not a secret.
NUGET_USER = "{{ nuget_user }}"
{% endif %}

[tasks."ci:git-config"]
run = """
git config --global core.compression 0
git config --global core.fsync -all
"""
description = "Optimize Git config for CI (disable compression, fsync)"
{% if has_go %}

[tasks."ci:build"]
run = "go build ./..."
description = "Compile every Go package in CI"

[tasks."ci:test"]
run = "go test -race -count=1 ./..."
description = "Run Go tests with the race detector"

[tasks."ci:lint"]
run = "golangci-lint run ./... --timeout=5m"
description = "Lint Go code in CI"
{% endif %}
{% if has_dotnet %}

[tasks."ci:restore"]
run = "dotnet restore {{ project_name_pascal }}.slnx --use-lock-file --locked-mode"
description = "Restore NuGet packages in locked mode (fails on lockfile drift)"
sources = [
    "src/**/*.csproj",
    "src/**/packages.lock.json",
    "{{ project_name_pascal }}.slnx",
    "Directory.Packages.props",
    "global.json",
    "nuget.config",
]
outputs = ["src/**/obj/project.assets.json"]

[tasks."ci:build"]
run = "dotnet build {{ project_name_pascal }}.slnx --configuration Release --no-restore"
description = "Build solution in Release without restoring"
sources = [
    "src/**/*.cs",
    "src/**/*.csproj",
    "{{ project_name_pascal }}.slnx",
    "Directory.Build.props",
    "Directory.Build.targets",
    "Directory.Packages.props",
    "global.json",
]
outputs = ["src/**/bin/Release/**/*"]

[tasks."ci:test"]
# TUnit (or any Microsoft Testing Platform-backed runner) on .NET 10 SDK
# rejects the legacy `dotnet test --logger trx` path. Invoke the test
# project as the executable it is. The project path uses
# `test_project_name` from the copier answers so consumers can match the
# NuGet package id rather than the repo's PascalCase name.
run = "dotnet run --project tests/{{ test_project_name }}.Tests --configuration Release --no-build -- --report-trx --coverage"
description = "Run tests via MTP with TRX report and coverage"

[tasks."ci:format-check"]
run = "dotnet format {{ project_name_pascal }}.slnx --verify-no-changes"
description = "Verify formatting in CI"

[tasks."ci:pack"]
run = "dotnet pack {{ project_name_pascal }}.slnx --configuration Release --no-build --output out/packages"
description = "Build NuGet packages for release"
sources = [
    "src/**/bin/Release/**/*.dll",
    "src/**/*.csproj",
    "src/**/PACKAGE.md",
    "Directory.Build.props",
    "Directory.Build.targets",
    "Directory.Packages.props",
]
outputs = ["out/packages/**/*"]
{% endif %}
{% if has_dart %}

[tasks."ci:get"]
run = "dart pub get --enforce-lockfile"
description = "Restore Dart dependencies in locked mode (fails on pubspec.lock drift)"
sources = ["pubspec.yaml", "pubspec.lock"]
outputs = [".dart_tool/package_config.json"]

[tasks."ci:analyze"]
run = "dart analyze --fatal-infos --fatal-warnings"
description = "Run the Dart analyzer with infos and warnings as failures"
sources = ["**/*.dart", "analysis_options.yaml"]

[tasks."ci:test"]
run = "dart test --reporter=expanded --coverage=coverage"
description = "Run Dart tests with coverage collection"
sources = ["**/*.dart", "pubspec.yaml", "dart_test.yaml"]
outputs = ["coverage/**/*"]

[tasks."ci:format-check"]
run = "dart format --output=none --set-exit-if-changed ."
description = "Verify Dart formatting in CI"
{% endif %}
