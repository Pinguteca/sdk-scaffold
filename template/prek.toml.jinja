default_stages = ["pre-commit"]
default_install_hook_types = [
  "pre-commit",
  "commit-msg",
  "pre-push",
  "post-checkout",
  "post-merge",
]
fail_fast = true

[[repos]]
repo = "https://github.com/pre-commit/pre-commit-hooks"
rev = "v6.0.0"
hooks = [
  { id = "check-added-large-files" },
  { id = "check-case-conflict" },
  { id = "check-executables-have-shebangs" },
  { id = "check-yaml" },
  { id = "check-json", exclude = "(\\.devcontainer|\\.vscode)/.*\\.json" },
  { id = "end-of-file-fixer"{% if has_dotnet %}, exclude = "packages\\.lock\\.json$"{% endif %} },
  { id = "fix-byte-order-marker" },
  { id = "mixed-line-ending", args = ["--fix=lf"] },
  { id = "trailing-whitespace" },
]

[[repos]]
repo = "https://github.com/mongodb/kingfisher"
rev = "v1.98.0"
hooks = [{ id = "kingfisher-pre-commit" }]

[[repos]]
repo = "local"
hooks = [
  {
    id = "cocogitto-commit-msg",
    name = "Cocogitto verify",
    language = "system",
    entry = "cog",
    args = ["verify", "--file"],
    stages = ["commit-msg"],
    pass_filenames = true,
  },
{% if has_dotnet %}
  {
    id = "dotnet-restore-lockfiles",
    name = "Verify NuGet lockfiles",
    language = "system",
    entry = "dotnet",
    args = ["restore", "--locked-mode"],
    files = "(\\.csproj|Directory\\.Packages\\.props)$",
    pass_filenames = false,
  },
{% endif %}
  {
    id = "pin-github-actions",
    name = "Pinact update GHA",
    language = "system",
    entry = "pinact",
    args = ["run", "-u", "--min-age", "7"],
    stages = ["pre-push"],
    pass_filenames = false,
  },
]
