[settings]
experimental = true
env_cache = true
env_cache_ttl = "9h"
install_before = "7d"
pin = true
lockfile = true
locked = false
prefer_offline = true
disable_default_registry = true
disable_backends = ["asdf", "vfox", "ubi"]

[tools]
"aqua:slsa-verifier" = "2.7.1"
{% if has_dotnet %}

[env]
# Public profile/org name on nuget.org. Consumed by NuGet/login@v1 via the
# `user` input in release-dotnet.yml. Gitted (public) rather than a GitHub
# repo variable: it is not a secret, and keeping it in mise.ci.toml avoids
# click-ops drift between repos. Override if your nuget.org account name
# differs from `vendor`.
NUGET_USER = "{{ vendor }}"
{% endif %}

[tasks."ci:git-config"]
run = """
git config --global core.compression 0
git config --global core.fsync -all
"""
description = "Optimize Git config for CI (disable compression, fsync)"
{% if has_go %}

[tasks."ci:build"]
run = "go build ./..."
description = "Compile every Go package in CI"

[tasks."ci:test"]
run = "go test -race -count=1 ./..."
description = "Run Go tests with the race detector"

[tasks."ci:lint"]
run = "golangci-lint run ./... --timeout=5m"
description = "Lint Go code in CI"
{% endif %}
{% if has_dotnet %}

[tasks."ci:restore"]
run = "dotnet restore {{ project_name_pascal }}.slnx --use-lock-file --locked-mode"
description = "Restore NuGet packages in locked mode (fails on lockfile drift)"

[tasks."ci:build"]
run = "dotnet build {{ project_name_pascal }}.slnx --configuration Release --no-restore"
description = "Build solution in Release without restoring"

[tasks."ci:test"]
# TUnit (or any Microsoft Testing Platform-backed runner) on .NET 10 SDK
# rejects the legacy `dotnet test --logger trx` path. Invoke the test
# project as the executable it is. The project path uses
# `test_project_name` from the copier answers so consumers can match the
# NuGet package id rather than the repo's PascalCase name.
run = "dotnet run --project tests/{{ test_project_name }}.Tests --configuration Release --no-build -- --report-trx --coverage"
description = "Run tests via MTP with TRX report and coverage"

[tasks."ci:format-check"]
run = "dotnet format {{ project_name_pascal }}.slnx --verify-no-changes"
description = "Verify formatting in CI"

[tasks."ci:pack"]
run = "dotnet pack {{ project_name_pascal }}.slnx --configuration Release --no-build --output out/packages"
description = "Build NuGet packages for release"
{% endif %}
