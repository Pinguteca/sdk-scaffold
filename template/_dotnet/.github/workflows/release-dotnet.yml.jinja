name: Release (.NET)

on:
  push:
    tags: ["v*"]
  workflow_dispatch:

permissions: {}

concurrency:
  group: {{ '${{ github.workflow }}-${{ github.ref }}' }}
  cancel-in-progress: false

env:
  CI: "true"
  MISE_ENV: ci
  DOTNET_NOLOGO: "true"
  DOTNET_CLI_TELEMETRY_OPTOUT: "true"

jobs:
  release:
    name: Pack and publish to NuGet
    runs-on: ubuntu-latest
    timeout-minutes: 25
    permissions:
      id-token: write
      contents: write
    outputs:
      hashes: {{ '${{ steps.hash.outputs.hashes }}' }}
    steps:
{% if harden_runner %}
      - name: Harden Runner
        uses: step-security/harden-runner@f808768d1510423e83855289c910610ca9b43176 # v2.17.0
        with:
          egress-policy: audit
          disable-telemetry: "true"
          disable-sudo: "true"
{% endif %}
      - name: Obtain release token
        id: octo-sts
        uses: octo-sts/action@f603d3be9d8dd9871a265776e625a27b00effe05 # v1.1.1
        with:
          scope: {{ github_owner }}/{{ project_name }}
          identity: release
      - name: Checkout
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
        with:
          fetch-depth: 0
          persist-credentials: false
          token: {{ '${{ steps.octo-sts.outputs.token }}' }}
      - name: Install mise and tools
        uses: jdx/mise-action@1648a7812b9aeae629881980618f079932869151 # v4.0.1
        with:
          experimental: true
        env:
          GITHUB_TOKEN: {{ '${{ steps.octo-sts.outputs.token }}' }}
      - name: Resolve version from tag
        id: version
        run: |
          TAG="{{ '${{ github.ref_name }}' }}"
          echo "version=${TAG#v}" >> "$GITHUB_OUTPUT"
      - name: Restore
        env:
          RELEASE_VERSION: {{ '${{ steps.version.outputs.version }}' }}
        run: mise run ci:restore
      - name: Build
        env:
          RELEASE_VERSION: {{ '${{ steps.version.outputs.version }}' }}
        run: mise run ci:build
      - name: Pack
        env:
          RELEASE_VERSION: {{ '${{ steps.version.outputs.version }}' }}
        run: mise run ci:pack
      - name: Generate SBOM
        run: mise run release:sbom
      - name: Compute checksums
        run: |
          cd out
          sha256sum packages/*.nupkg packages/*.snupkg sbom/{{ project_name }}.cdx.json > checksums.txt 2>/dev/null || true
      - name: Install cosign
        uses: sigstore/cosign-installer@cad07c2e89fa2edd6e2d7bab4c1aa38e53f76003 # v4.1.1
      - name: Sign checksums
        run: |
          cd out
          cosign sign-blob \
            --bundle=checksums.txt.sigstore.json \
            --yes \
            checksums.txt
      - name: Compute SLSA subject hashes
        id: hash
        run: |
          echo "hashes=$(base64 -w0 out/checksums.txt)" >> "$GITHUB_OUTPUT"
      # NuGet Trusted Publishing: the job's GitHub OIDC token is exchanged
      # for a 1-hour API key at push time. No long-lived secret in the
      # repo. Policy on nuget.org binds this workflow file name to the
      # publisher account; first push under a new package id creates the
      # package owned by that account. NUGET_USER comes from mise.ci.toml.
      # See https://learn.microsoft.com/nuget/nuget-org/trusted-publishing
      - name: NuGet login (OIDC to short-lived API key)
        id: nuget-login
        uses: NuGet/login@8d196754b4036150537f80ac539e15c2f1028841 # v1.2.0
        with:
          user: {{ '${{ env.NUGET_USER }}' }}
      - name: Push to NuGet.org
        run: |
          dotnet nuget push "out/packages/*.nupkg" \
            --source "https://api.nuget.org/v3/index.json" \
            --api-key "{{ '${{ steps.nuget-login.outputs.NUGET_API_KEY }}' }}" \
            --skip-duplicate
      # GitHub releases on org-immutable repos cannot have assets
      # deleted, so softprops's delete-and-replace flow fails on
      # every retry. Atomic gh release create on first run, no-op
      # on retry.
      - name: Create GitHub Release
        env:
          GH_TOKEN: {{ '${{ steps.octo-sts.outputs.token }}' }}
          TAG: {{ '${{ github.ref_name }}' }}
        run: |
          if gh release view "$TAG" --repo "$GITHUB_REPOSITORY" >/dev/null 2>&1; then
            echo "Release $TAG already exists; skipping create."
            exit 0
          fi
          gh release create "$TAG" \
            --repo "$GITHUB_REPOSITORY" \
            --generate-notes \
            out/packages/*.nupkg \
            out/sbom/{{ project_name }}.cdx.json \
            out/checksums.txt \
            out/checksums.txt.sigstore.json

  provenance:
    name: SLSA provenance
    needs: release
    permissions:
      actions: read
      id-token: write
      contents: write
    uses: slsa-framework/slsa-github-generator/.github/workflows/generator_generic_slsa3.yml@v2.1.0
    with:
      base64-subjects: "{{ '${{ needs.release.outputs.hashes }}' }}"
      # Keep provenance as a workflow artifact only. Attaching to the
      # GitHub Release races whichever tool owns the release lifecycle
      # (softprops today, possibly GoReleaser/JReleaser later) and SLSA
      # verifiers pull provenance from the workflow run, not the release.
      upload-assets: false
      provenance-name: provenance.intoto.jsonl
      private-repository: {{ "false" if public_repo else "true" }}
