# Strict Dart analyzer configuration. Trades a touch of cognitive
# load for catching bugs that the default analyzer lets through.
include: package:lints/recommended.yaml

analyzer:
  language:
    strict-casts: true
    strict-inference: true
    strict-raw-types: true
  errors:
    # Surface common bug patterns as errors rather than warnings.
    invalid_annotation_target: ignore
    todo: ignore
    unused_import: error
    unused_local_variable: error
    dead_code: error

linter:
  rules:
    # Style
    - prefer_single_quotes
    - prefer_const_constructors
    - prefer_const_declarations
    - prefer_final_locals
    - prefer_final_fields
    - prefer_relative_imports
    - directives_ordering
    - sort_pub_dependencies
    # Correctness
    - always_declare_return_types
    - avoid_dynamic_calls
    - avoid_returning_null_for_future
    - cancel_subscriptions
    - close_sinks
    - throw_in_finally
    - unawaited_futures
    - use_build_context_synchronously
    # API hygiene
    - public_member_api_docs
    - require_trailing_commas
